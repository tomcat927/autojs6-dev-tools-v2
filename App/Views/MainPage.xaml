<Page
    x:Class="App.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:App.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <SolidColorBrush x:Key="ExitCropButtonNormalBrush" Color="#D14343" />
        <SolidColorBrush x:Key="ExitCropButtonPointerOverBrush" Color="#C53A3A" />
        <SolidColorBrush x:Key="ExitCropButtonPressedBrush" Color="#A93131" />
        <SolidColorBrush x:Key="ExitCropButtonDisabledBrush" Color="#66D14343" />

        <Style x:Key="ExitCropButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource ExitCropButtonNormalBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ExitCropButtonNormalBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="1">
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Padding="{TemplateBinding Padding}" />
                        </Border>

                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder"
                                                                       Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource ExitCropButtonPointerOverBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder"
                                                                       Storyboard.TargetProperty="BorderBrush">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource ExitCropButtonPointerOverBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder"
                                                                       Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource ExitCropButtonPressedBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder"
                                                                       Storyboard.TargetProperty="BorderBrush">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource ExitCropButtonPressedBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder"
                                                                       Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource ExitCropButtonDisabledBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder"
                                                                       Storyboard.TargetProperty="BorderBrush">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource ExitCropButtonDisabledBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                        <DoubleAnimation Storyboard.TargetName="RootBorder"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.72"
                                                         Duration="0:0:0" />
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CodePreviewTabToggleButtonStyle"
               TargetType="ToggleButton"
               BasedOn="{StaticResource WorkbenchSecondaryToggleButtonStyle}">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="0,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource WorkbenchCardBorderStyle}" Margin="16,16,16,12" Padding="16,14">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="AutoJS6 可视化工作台" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock x:Name="CurrentDeviceSummaryText"
                               Text="当前设备：尚未选择"
                               Style="{StaticResource WorkbenchCaptionTextStyle}" />
                </StackPanel>

                <Border Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="4">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <ToggleButton x:Name="ImageModeButton"
                                      Content="图像模式"
                                      IsChecked="True"
                                      Click="ImageModeButton_Click"
                                      Style="{StaticResource WorkbenchModeButtonStyle}" />
                        <ToggleButton x:Name="UiModeButton"
                                      Content="控件模式"
                                      Click="UiModeButton_Click"
                                      Style="{StaticResource WorkbenchModeButtonStyle}" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Button x:Name="CaptureButton"
                            Click="CaptureButton_Click"
                            Style="{StaticResource WorkbenchPrimaryButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Camera" />
                            <TextBlock Text="截图" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="LoadLocalTopButton"
                            Click="LoadLocalImageButton_Click"
                            Style="{StaticResource WorkbenchSecondaryButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="OpenFile" />
                            <TextBlock Text="载入图片" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="16,0,16,12" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="336" />
            </Grid.ColumnDefinitions>

            <local:AdbDeviceListView x:Name="DeviceList" Grid.Column="0" />

            <Grid Grid.Column="1" RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource WorkbenchCardBorderStyle}" Padding="8,6">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel x:Name="ImageToolbarPanel"
                                    Grid.Column="0"
                                    Orientation="Horizontal"
                                    Spacing="8">
                            <Button x:Name="FitToWindowButton"
                                    Click="FitToWindowButton_Click"
                                    Style="{StaticResource WorkbenchSecondaryButtonStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE740;" />
                                    <TextBlock Text="适应窗口" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="ResetViewButton"
                                    Click="ResetViewButton_Click"
                                    Style="{StaticResource WorkbenchSecondaryButtonStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE7C4;" />
                                    <TextBlock Text="原图 1:1" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="EnterCropButton"
                                    Click="EnterCropButton_Click"
                                    Style="{StaticResource WorkbenchPrimaryButtonStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE16E;" />
                                    <TextBlock Text="开始裁剪" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="ExitCropButton"
                                    Click="ExitCropButton_Click"
                                    Style="{StaticResource ExitCropButtonStyle}"
                                    Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE10A;" Foreground="White" />
                                    <TextBlock Text="退出裁剪" Foreground="White" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <StackPanel x:Name="UiToolbarPanel"
                                    Grid.Column="0"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    Visibility="Collapsed">
                            <Button x:Name="DumpUiStageButton"
                                    Click="DumpUiButton_Click"
                                    Style="{StaticResource WorkbenchPrimaryButtonStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <SymbolIcon Symbol="ViewAll" />
                                    <TextBlock Text="拉取 UI 树" />
                                </StackPanel>
                            </Button>
                            <CheckBox x:Name="WidgetBoundsCheckBox"
                                      Content="显示控件框"
                                      IsChecked="True"
                                      VerticalAlignment="Center"
                                      Checked="WidgetBoundsCheckBox_Changed"
                                      Unchecked="WidgetBoundsCheckBox_Changed" />
                        </StackPanel>

                        <Button x:Name="RestoreStageButton"
                                Grid.Column="1"
                                Click="RestoreStageButton_Click"
                                Style="{StaticResource WorkbenchSecondaryButtonStyle}"
                                Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE777;" />
                                <TextBlock Text="恢复现场" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="ClearStageButton"
                                Grid.Column="2"
                                Click="ClearStageButton_Click"
                                Style="{StaticResource WorkbenchSecondaryButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Delete" />
                                <TextBlock Text="清屏" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource WorkbenchCardBorderStyle}" Padding="0">
                    <Grid x:Name="CanvasHostGrid" AllowDrop="True" DragOver="CanvasHost_DragOver" Drop="CanvasHost_Drop">
                        <Border Margin="14"
                                Background="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                                BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="1"
                                CornerRadius="14" />

                        <local:CanvasView x:Name="Canvas" Margin="14" />

                        <Grid x:Name="StageEmptyStateOverlay"
                              Margin="14"
                              Background="#26FFFFFF"
                              Visibility="Visible">
                            <Border HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="{ThemeResource SystemControlBackgroundAltHighBrush}"
                                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="20"
                                    MaxWidth="360">
                                <StackPanel Spacing="10" HorizontalAlignment="Center">
                                    <TextBlock Text="画布尚未加载截图"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="选择设备后点击截图，或直接载入本地图片开始工作。"
                                               Style="{StaticResource WorkbenchCaptionTextStyle}"
                                               TextAlignment="Center" />
                                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                                        <Button Content="立即截图"
                                                Click="CaptureButton_Click"
                                                Style="{StaticResource WorkbenchPrimaryButtonStyle}" />
                                        <Button Content="载入图片"
                                                Click="LoadLocalImageButton_Click"
                                                Style="{StaticResource WorkbenchSecondaryButtonStyle}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource WorkbenchCardBorderStyle}" Padding="8,6">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="14">
                            <TextBlock x:Name="HudModeText" Text="模式：图像模式" FontWeight="SemiBold" />
                            <TextBlock x:Name="HudResolutionText" Text="分辨率：-" Style="{StaticResource WorkbenchCaptionTextStyle}" />
                            <TextBlock x:Name="HudScaleText" Text="缩放：100%" Style="{StaticResource WorkbenchCaptionTextStyle}" />
                            <TextBlock x:Name="HudCropText" Text="裁剪区域：-" Style="{StaticResource WorkbenchCaptionTextStyle}" />
                        </StackPanel>

                        <TextBlock x:Name="MatchSummaryText"
                                   Grid.Column="1"
                                   Text="匹配：-"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Style="{StaticResource WorkbenchCaptionTextStyle}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="280" />
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="2" Style="{StaticResource WorkbenchCardBorderStyle}" Padding="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Padding="10">
                    <Grid x:Name="ImageInspectorPanel">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource WorkbenchCardBorderStyle}" Padding="10" Margin="0,0,0,10">
                            <StackPanel Spacing="8">
                                <TextBlock Text="来源" Style="{StaticResource WorkbenchSectionTitleTextStyle}" />

                                <Grid ColumnSpacing="8" RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="模板" VerticalAlignment="Center" />
                                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="10">
                                        <RadioButton x:Name="TemplateSourceCrop"
                                                     Content="当前"
                                                     IsChecked="True"
                                                     Checked="TemplateSource_Changed" />
                                        <RadioButton x:Name="TemplateSourceFile"
                                                     Content="文件"
                                                     Checked="TemplateSource_Changed" />
                                    </StackPanel>
                                    <Button x:Name="TemplateBrowseButton"
                                            Grid.Row="0"
                                            Grid.Column="2"
                                            Content="浏览"
                                            Click="BrowseTemplateButton_Click"
                                            Style="{StaticResource WorkbenchSecondaryButtonStyle}" />

                                    <TextBlock Grid.Row="1"
                                               Grid.Column="1"
                                               Grid.ColumnSpan="2"
                                               x:Name="TemplateSourceSummaryText"
                                               Text="当前裁剪：尚未创建区域"
                                               Style="{StaticResource WorkbenchCaptionTextStyle}"
                                               TextWrapping="WrapWholeWords" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="截图" VerticalAlignment="Center" />
                                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="10">
                                        <RadioButton x:Name="ScreenshotSourceCurrent"
                                                     Content="当前"
                                                     IsChecked="True"
                                                     Checked="ScreenshotSource_Changed" />
                                        <RadioButton x:Name="ScreenshotSourceFile"
                                                     Content="文件"
                                                     Checked="ScreenshotSource_Changed" />
                                    </StackPanel>
                                    <Button x:Name="ScreenshotBrowseButton"
                                            Grid.Row="2"
                                            Grid.Column="2"
                                            Content="浏览"
                                            Click="BrowseScreenshotButton_Click"
                                            Style="{StaticResource WorkbenchSecondaryButtonStyle}" />

                                    <TextBlock Grid.Row="3"
                                               Grid.Column="1"
                                               Grid.ColumnSpan="2"
                                               x:Name="ScreenshotSourceSummaryText"
                                               Text="当前画布：尚未加载截图"
                                               Style="{StaticResource WorkbenchCaptionTextStyle}"
                                               TextWrapping="WrapWholeWords" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource WorkbenchCardBorderStyle}" Padding="10">
                                <Grid RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="操作" Style="{StaticResource WorkbenchSectionTitleTextStyle}" />

                                <Grid Grid.Row="1" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="RegionRefTextBox"
                                             Grid.Column="0"
                                             Text="[等待裁剪...]"
                                             IsReadOnly="True"
                                             Style="{StaticResource WorkbenchMonoTextStyle}" />
                                    <Button Grid.Column="1"
                                            Content="复制"
                                            Click="CopyRegionRefButton_Click"
                                            Style="{StaticResource WorkbenchSecondaryButtonStyle}" />
                                </Grid>

                                <Grid Grid.Row="2" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="42" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="阈值" VerticalAlignment="Center" />
                                    <Slider x:Name="ThresholdSlider"
                                            Grid.Column="1"
                                            Minimum="0.5"
                                            Maximum="0.95"
                                            Value="0.84"
                                            StepFrequency="0.01"
                                            ValueChanged="ThresholdSlider_ValueChanged"
                                            VerticalAlignment="Center" />
                                    <TextBlock x:Name="ThresholdValueText"
                                               Grid.Column="2"
                                               Text="0.84"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right" />
                                </Grid>

                                <Grid Grid.Row="3" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox x:Name="FullImageSearchCheckBox"
                                              Grid.Column="0"
                                              Content="全图搜索（默认使用区域搜索）"
                                              VerticalAlignment="Center" />
                                    <Button x:Name="TestMatchButton"
                                            Grid.Column="1"
                                            Content="执行测试"
                                            Click="TestMatchButton_Click"
                                            Style="{StaticResource WorkbenchPrimaryButtonStyle}" />
                                </Grid>

                                <Grid Grid.Row="4" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="SaveFolderText"
                                               Grid.Column="0"
                                               Text="-"
                                               VerticalAlignment="Center"
                                               Style="{StaticResource WorkbenchCaptionTextStyle}"
                                               TextWrapping="WrapWholeWords" />
                                    <Button Grid.Column="1"
                                            Content="代码目录"
                                            Click="SelectSaveFolderButton_Click"
                                            Style="{StaticResource WorkbenchSecondaryButtonStyle}" />
                                </Grid>

                                <TextBox x:Name="TemplateNameTextBox"
                                         Grid.Row="5"
                                         PlaceholderText="模板名（代码文件名优先取这里，留空则跟模板名）" />

                                <Grid Grid.Row="6" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="SaveTemplateButton"
                                            Grid.Column="0"
                                            Content="保存模板"
                                            Click="SaveTemplateButton_Click"
                                            Style="{StaticResource WorkbenchSecondaryButtonStyle}" />
                                    <Button x:Name="GenerateCodeButton"
                                            Grid.Column="1"
                                            Content="生成代码"
                                            Click="GenerateCodeButton_Click"
                                            Style="{StaticResource WorkbenchPrimaryButtonStyle}" />
                                    <Button x:Name="ViewCodeRightButton"
                                            Grid.Column="2"
                                            Content="查看代码"
                                            Click="ViewCodeButton_Click"
                                            Style="{StaticResource WorkbenchSecondaryButtonStyle}" />
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid x:Name="UiInspectorPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="230" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource WorkbenchCardBorderStyle}" Padding="12" Margin="0,0,0,12">
                            <Grid RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid ColumnSpacing="8">
                                    <TextBlock Text="节点树" Style="{StaticResource WorkbenchSectionTitleTextStyle}" />
                                </Grid>

                                <StackPanel Grid.Row="1" Spacing="6">
                                    <TextBox x:Name="UiSearchTextBox"
                                             PlaceholderText="搜索 class / text / desc / resource-id"
                                             TextChanged="UiSearchTextBox_TextChanged" />
                                    <TextBlock x:Name="UiTreeSummaryText"
                                               Text="尚未拉取 UI 树"
                                               Style="{StaticResource WorkbenchCaptionTextStyle}" />
                                </StackPanel>

                                <TreeView x:Name="UiNodeTreeView"
                                          Grid.Row="2"
                                          ItemInvoked="UiNodeTreeView_ItemInvoked"
                                          SelectionMode="Single" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource WorkbenchCardBorderStyle}" Padding="12">
                            <Grid RowSpacing="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="属性与代码动作" Style="{StaticResource WorkbenchSectionTitleTextStyle}" />

                                <Grid Grid.Row="1" ColumnSpacing="10" RowSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="64" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="类名" Style="{StaticResource WorkbenchCaptionTextStyle}" />
                                    <TextBlock Grid.Column="1" x:Name="SelectedWidgetClassText" Text="-" TextWrapping="Wrap" />
                                    <TextBlock Grid.Row="1" Text="文本" Style="{StaticResource WorkbenchCaptionTextStyle}" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="SelectedWidgetTextText" Text="-" TextWrapping="Wrap" />
                                    <TextBlock Grid.Row="2" Text="ID" Style="{StaticResource WorkbenchCaptionTextStyle}" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="SelectedWidgetResourceIdText" Text="-" TextWrapping="Wrap" />
                                </Grid>

                                <local:PropertyPanelView x:Name="PropertyPanel" Grid.Row="2" />

                                <Grid Grid.Row="3" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="CopyCoordinatesButton"
                                            Grid.Column="0"
                                            Content="复制坐标"
                                            Click="CopyCoordinatesButton_Click"
                                            Style="{StaticResource WorkbenchSecondaryButtonStyle}" />
                                    <Button x:Name="CopySelectorButton"
                                            Grid.Column="1"
                                            Content="复制选择"
                                            Click="CopySelectorButton_Click"
                                            Style="{StaticResource WorkbenchSecondaryButtonStyle}" />
                                    <Button x:Name="PreviewWidgetSnippetButton"
                                            Grid.Column="2"
                                            Content="查看代码"
                                            Click="PreviewWidgetSnippetButton_Click"
                                            Style="{StaticResource WorkbenchPrimaryButtonStyle}" />
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Margin="16,0,16,0"
                Background="{ThemeResource SystemControlBackgroundAltHighBrush}"
                BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12,10">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border x:Name="StatusPillBorder"
                        Grid.Column="0"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10,6"
                        HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon x:Name="StatusIcon" Glyph="&#xE946;" />
                        <TextBlock x:Name="StatusText" Text="就绪" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <TextBlock x:Name="ScaleText" Grid.Column="1" Text="缩放：100%" VerticalAlignment="Center" />
                <TextBlock x:Name="ResolutionText" Grid.Column="2" Text="分辨率：-" VerticalAlignment="Center" />
                <TextBlock x:Name="ModeStatusText"
                           Grid.Column="3"
                           Text="当前模式：图像模式"
                           VerticalAlignment="Center"
                           Style="{StaticResource WorkbenchCaptionTextStyle}" />
                <HyperlinkButton x:Name="AboutAuthorButton"
                                 Grid.Column="4"
                                 Content="关于作者"
                                 Click="AboutAuthorButton_Click"
                                 Padding="4,0"
                                 VerticalAlignment="Center"
                                 FontSize="12" />
                <Button x:Name="ShowLogButton"
                        Grid.Column="5"
                        Content="查看日志"
                        Click="ShowLogDockButton_Click"
                        Style="{StaticResource WorkbenchSecondaryButtonStyle}" />
            </Grid>
        </Border>

        <Border x:Name="BottomDockPanel"
                Grid.Row="3"
                Margin="16,10,16,16"
                Background="{ThemeResource SystemControlBackgroundAltHighBrush}"
                BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                CornerRadius="12"
                MaxHeight="240"
                Visibility="Collapsed">
            <TextBox x:Name="DebugLogText"
                     Padding="12"
                     FontFamily="Consolas"
                     FontSize="12"
                     TextWrapping="Wrap"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     BorderThickness="0"
                     Background="Transparent">
                <TextBox.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="清空日志" Click="ClearLogButton_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE74D;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="全选" Click="SelectAllLogButton_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE8B3;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="复制" Click="CopyLogButton_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE8C8;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </TextBox.ContextFlyout>
            </TextBox>
        </Border>

        <Border x:Name="ActionFeedbackToast"
                Grid.RowSpan="4"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,20,20,0"
                MaxWidth="380"
                Padding="12,10"
                CornerRadius="12"
                BorderThickness="1"
                Visibility="Collapsed"
                Opacity="0"
                IsHitTestVisible="False"
                Canvas.ZIndex="20">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon x:Name="ActionFeedbackToastIcon"
                          VerticalAlignment="Top"
                          Margin="0,2,0,0" />
                <TextBlock x:Name="ActionFeedbackToastText"
                           TextWrapping="WrapWholeWords"
                           MaxLines="2" />
            </StackPanel>
        </Border>

        <ContentDialog x:Name="CodePreviewDialog"
                       Title="代码预览"
                       PrimaryButtonText="复制代码"
                       PrimaryButtonClick="CodePreviewDialog_PrimaryButtonClick"
                       CloseButtonText="关闭"
                       DefaultButton="Primary"
                       MinWidth="820"
                       MaxWidth="820">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="56" />
                    <RowDefinition Height="46" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid x:Name="CodePreviewMetaPanel"
                      Grid.Row="0"
                      RowSpacing="4"
                      Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="20" />
                        <RowDefinition Height="28" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="CodePreviewTemplateDescriptionText"
                               Grid.Row="0"
                               TextWrapping="Wrap"
                               MaxLines="1"
                               TextTrimming="CharacterEllipsis"
                               Style="{StaticResource WorkbenchCaptionTextStyle}"
                               Visibility="Collapsed" />
                    <HyperlinkButton x:Name="CodePreviewGistButton"
                                     Grid.Row="1"
                                     Content="打开 GitHub Gist"
                                     Click="CodePreviewGistButton_Click"
                                     Visibility="Collapsed"
                                     Padding="0"
                                     HorizontalAlignment="Left" />
                </Grid>

                <Grid x:Name="CodePreviewTemplateStrip"
                      Grid.Row="1"
                      ColumnSpacing="8"
                      Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ToggleButton x:Name="CodePreviewReferenceTabButton"
                                  Grid.Column="0"
                                  Content="封装版"
                                  Click="CodePreviewReferenceTabButton_Click"
                                  Style="{StaticResource CodePreviewTabToggleButtonStyle}" />
                    <ToggleButton x:Name="CodePreviewMatchTemplateTabButton"
                                  Grid.Column="1"
                                  Content="图像匹配"
                                  Click="CodePreviewMatchTemplateTabButton_Click"
                                  Style="{StaticResource CodePreviewTabToggleButtonStyle}" />
                    <ToggleButton x:Name="CodePreviewMatchFeatureTabButton"
                                  Grid.Column="2"
                                  Content="特征匹配"
                                  Click="CodePreviewMatchFeatureTabButton_Click"
                                  Style="{StaticResource CodePreviewTabToggleButtonStyle}" />
                </Grid>

                <local:CodePreviewView x:Name="CodePreviewDialogView"
                                       Grid.Row="2"
                                       Height="280" />
            </Grid>
        </ContentDialog>
    </Grid>
</Page>
